{
  "name": "@incident/workers",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "demo:seed": "tsx src/demo-seed.ts",
    "lint": "eslint src --max-warnings 0",
    "start": "node dist/server.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"

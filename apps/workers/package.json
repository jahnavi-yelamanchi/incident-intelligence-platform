  "dependencies": {
    "@incident/database": "workspace:*",
    "@incident/queues": "workspace:*",
    "bullmq": "latest",
    "pino": "latest",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/node": "^22.15.30",
    "eslint": "^9.28.0",
    "tsx": "latest",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.0",
    "vitest": "^3.2.3"
  }
}

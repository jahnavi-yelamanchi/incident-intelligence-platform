{
  "name": "@incident/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "lint": "eslint src --max-warnings 0",
    "start": "node dist/server.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "latest",
    "@fastify/helmet": "latest",
    "@fastify/rate-limit": "latest",
    "@fastify/swagger": "latest",
    "@fastify/swagger-ui": "latest",
    "@incident/contracts": "workspace:*",
    "@incident/database": "workspace:*",
    "@incident/investigation": "workspace:*",
    "@incident/queues": "workspace:*",
    "@incident/workflows": "workspace:*",
    "@temporalio/client": "latest",
    "fastify": "latest",
    "fastify-raw-body": "latest",
    "jose": "latest",
    "pino": "latest",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/node": "^22.15.30",
    "eslint": "^9.28.0",
    "tsx": "latest",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.0",
    "vitest": "^3.2.3"
  }
}
